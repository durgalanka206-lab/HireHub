# HireHub-AI — Environment Variables Template
# Copy this file to .env and fill in the values.
# NEVER commit the actual .env file to version control.

# ── Server ──────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── Database ────────────────────────────────────────────────────
MONGO_URI=your_mongodb_connection_string_here

# ── Auth ────────────────────────────────────────────────────────
JWT_SECRET=your_strong_jwt_secret_here
JWT_EXPIRES_IN=7d
SESSION_SECRET=your_session_secret_here

# ── Email (Nodemailer) ──────────────────────────────────────────
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password_here

# ── Google OAuth ────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# ── URLs ────────────────────────────────────────────────────────
BACKEND_URL=http://localhost:5000
CLIENT_URL=http://localhost:3000

# ── AI Configuration ────────────────────────────────────────────
# Active provider: gemini | openai | openrouter | groq | ollama
AI_PROVIDER=gemini

# Gemini — get a free API key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# OpenAI (future)
# OPENAI_API_KEY=your_openai_api_key_here

# OpenRouter (future — access to many models via one key)
# OPENROUTER_API_KEY=your_openrouter_api_key_here

# Groq (future — ultra-fast inference)
# GROQ_API_KEY=your_groq_api_key_here

# Ollama (future — local models, no API key needed)
# OLLAMA_BASE_URL=http://localhost:11434
